---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Support"
  description="L1 Library is free and open source. Support the project with a donation or GitHub sponsorship."
>
  <div class="max-w-3xl mx-auto px-4 pt-12 pb-16 w-full">
    <div class="double-rule mb-6"></div>
    <h1 class="font-mono text-4xl font-bold tracking-tight mb-6">Support L1 Library</h1>

    <p class="text-lg text-l1-gray-700 mb-10 text-pretty">
      L1 Library is free, open source, and has no ads. All donations go
      toward hosting, content development, and keeping the project
      independent.
    </p>

    <div class="single-rule mb-4"></div>
    <h2 class="kicker mb-3">GitHub Sponsors</h2>
    <p class="text-l1-gray-700 mb-4">
      The easiest way to support ongoing development. Monthly or one-time.
    </p>
    <a href="https://github.com/sponsors/HashHashShawn" target="_blank" rel="noopener" class="inline-block font-mono text-sm border-[1.5px] border-l1-black px-4 py-2 hover:bg-l1-black hover:text-white transition-colors mb-10">Sponsor on GitHub →</a>

    <div class="single-rule mb-4"></div>
    <h2 class="kicker mb-3">Crypto</h2>
    <p class="text-l1-gray-700 mb-6">
      Send directly to the project wallet. Every contribution helps.
    </p>

    <div class="mb-10">
      <div class="py-4 border-b border-dotted border-l1-gray-200">
        <span class="font-mono text-sm font-semibold text-l1-black">ETH</span>
        <span class="text-sm text-l1-gray-500 ml-2">Ethereum (ERC-20)</span>
        <div class="mt-2">
          <code class="block bg-l1-gray-50 border border-l1-gray-200 px-3 py-2 text-sm font-mono break-all select-all">0xc3f8Ca91C3e14C41b7e7d97F423B702acb109a0A</code>
        </div>
      </div>
    </div>

    <div class="single-rule mb-4"></div>
    <h2 class="kicker mb-3">Other Ways to Help</h2>
    <ul class="mb-10">
      <li class="py-2.5 border-b border-dotted border-l1-gray-200">
        <span class="font-semibold text-l1-black">Star the repo</span>
        <span class="text-sm text-l1-gray-600"> — helps others find L1 Library on GitHub.</span>
      </li>
      <li class="py-2.5 border-b border-dotted border-l1-gray-200">
        <span class="font-semibold text-l1-black">Contribute content</span>
        <span class="text-sm text-l1-gray-600"> — chain profiles, concept fixes, translations. See the <a href="https://github.com/HashHashShawn/L1Library/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener" class="underline hover:text-l1-black">contributing guide</a>.</span>
      </li>
      <li class="py-2.5">
        <span class="font-semibold text-l1-black">Share it</span>
        <span class="text-sm text-l1-gray-600"> — link to a page you found useful. Word of mouth is everything for open source.</span>
      </li>
    </ul>
  </div>
</BaseLayout>
